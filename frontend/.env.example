# Frontend env. Copy to .env and set if needed.

# Supabase (required)
# VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJ...

# Public app URL for magic-link and password-reset redirects in emails.
# Local dev: omit to use window.location.origin (http://localhost:5173).
# Production: set to your deployed origin, e.g. https://app.example.com
# VITE_APP_URL=https://app.example.com

# API base URL. Leave unset to use Vite proxy (/api -> http://localhost:8000).
# VITE_API_URL=http://localhost:8000

# Add to Supabase Dashboard → Authentication → URL configuration → Redirect URLs:
#   http://localhost:5173/auth/callback
#   http://localhost:5173/auth/reset-password
# Production (include both apex and www if you use either):
#   https://surface.best/auth/callback
#   https://www.surface.best/auth/callback
#   https://surface.best/auth/reset-password
#   https://www.surface.best/auth/reset-password
# Also allow the site root if Supabase Site URL is "/" (tokens in hash):
#   https://surface.best/
#   https://www.surface.best/
#
# Vercel: deploy with frontend/vercel.json so /auth/* requests serve index.html (SPA fallback).
#
# Site URL can be the app root (e.g. http://localhost:5173). If email links land on "/" with
# tokens in the hash, Layout.tsx redirects to /auth/callback or /auth/reset-password.

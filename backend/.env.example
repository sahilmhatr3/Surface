# Copy to .env and set values. Never commit .env.

# Database (default works for local Postgres)
# DATABASE_URL=postgresql://surface:surface@localhost:5432/surface

# Required in production: use a long random string (e.g. openssl rand -hex 32)
SECRET_KEY=change-me-in-production-dev-only

# Optional overrides
# ACCESS_TOKEN_EXPIRE_MINUTES=10080
# CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

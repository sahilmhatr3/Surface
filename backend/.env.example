# Copy to .env and set values. Never commit .env.

# Database (Supabase pooler URL recommended for IPv4 compatibility)
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# Supabase — required in production
SUPABASE_URL=https://[your-project-ref].supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_JWT_SECRET=your-jwt-secret
# Same anon key as the frontend — optional; enables password-reset email if invite fails (duplicate Auth user)
# SUPABASE_ANON_KEY=eyJ...

# Where users land after invite / magic link (must match an entry in Supabase → Auth → URL configuration → Redirect URLs)
# Defaults to first CORS_ORIGINS entry, or http://localhost:5173
# APP_PUBLIC_URL=http://localhost:5173

# OpenAI — required for rant anonymization and AI-generated insights
OPENAI_API_KEY=sk-...

# Optional overrides
# ANONYMITY_THRESHOLD=1
# CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
